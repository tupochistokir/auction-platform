PUBLIC_BASE_URL=https://auction-platform-api.onrender.com
FRONTEND_ORIGINS=https://your-domain.ru,https://your-project.vercel.app
DATABASE_URL=postgresql://auction_user:password@host:5432/auction_platform
SQLITE_BACKUP_PATH=auction.db
UPLOAD_DIR=/var/data/uploads
AUCTION_AUTH_SECRET=change-this-to-a-long-random-string

# Optional: Gemini image analysis for pricing evidence.
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=25
